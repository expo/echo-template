{
  "expo": {
    "icon": "https://agent.expo.app/static/icon.png",
    "orientation": "default",
    "scheme": "acme",
    "userInterfaceStyle": "automatic",
    "web": {
      "output": "server"
    },
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "experiments": {
      "reactCompiler": true
    },
    "plugins": [
      "expo-font",
      "expo-image",
      "expo-router",
      "expo-web-browser",
      "@rnrepo/expo-config-plugin"
    ]
  }
}
